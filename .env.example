# Copy to .env — used by docker-compose.yml
MYSQL_DATABASE=travel_log
MYSQL_USER=travel
MYSQL_PASSWORD=travel
MYSQL_ROOT_PASSWORD=root

# Allowed frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Set to true in production behind HTTPS
COOKIE_SECURE=false

# Session lifetime in hours (168 = 7 days)
SESSION_LIFETIME_HOURS=168

# Login brute-force protection
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_FAILURE_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MINUTES=15

# Backend URL the browser should call
VITE_API_URL=http://localhost:8000

# S3 database backups
AWS_REGION=eu-north-1
# Must be globally unique; S3 bucket names cannot contain underscores.
S3_BUCKET=s3-travellog-nirl10
S3_PREFIX=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
