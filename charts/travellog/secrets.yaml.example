# Copy to secrets.yaml (same directory) and fill in real values for your
# environment. secrets.yaml is gitignored — NEVER commit it. Install/upgrade
# with both files layered:
#
#   helm install travellog . -f values.yaml -f secrets.yaml
#
# These map 1:1 to the credential vars in ../../.env.example.
secrets:
  mysqlUser: travel
  mysqlPassword: CHANGE_ME
  mysqlRootPassword: CHANGE_ME
